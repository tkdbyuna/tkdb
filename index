       ${passives.map(p=>`<div class="skill"><div class="sk-name">${p.name||'—'}</div>${p.description?`<div class="sk-desc">${p.description}</div>`:''}</div>`).join('')}
     </div>`:''}

     <div class="sec">
       <h4>랭크 점수 분해 <span class="cnt">0–100 정규화</span></h4>
       <div class="brk">${subRows}</div>
       <div class="method" style="margin-top:14px">
         <b>산정 방식</b> — 각 축을 전체 SSR 풀 내에서 min–max 정규화 후 현재 가중치로 가중 평균합니다.<br>
         공격 효율 = max( 배율 × 대상수 ÷ 행동지연 ) · 순간 화력 = max( 배율 × 대상수 )<br>
         행동지연 = <code>ceil((TU−100)/10)</code> · 진입지연 = <code>ceil((Speed−100)/10)</code><br>
         MP는 <b>5</b>로 시작해 <b>0–10</b> 사이에서 스킬별로 증감(음수 불가), 광역(All)은 ${AOE_ENEMIES}체 조우로 계산.
       </div>
     </div>

   </div>`;
  document.getElementById('overlay').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeCard(){ document.getElementById('overlay').classList.remove('open'); document.body.style.overflow=''; }
document.getElementById('overlay').onclick=e=>{ if(e.target.id==='overlay') closeCard(); };
document.addEventListener('keydown',e=>{ if(e.key==='Escape') closeCard(); });

/* ---------- go ---------- */
buildControls();
render();

</script>
</body>
</html>
