function segSet(sel,btn){ document.querySelectorAll(sel+' button').forEach(b=>b.classList.remove('on')); btn.classList.add('on'); }

/* ---------- filtering + render ---------- */
function filtered(){
  let list = CARDS.filter(c=>{
    if(state.house!=='ALL' && c.house!==state.house) return false;
    if(state.color!=='ALL' && c.card_type!==state.color) return false;
    if(state.stype!=='ALL' && c.skill_type!==state.stype) return false;
    if(state.q){
      const blob=(c.full_name+' '+c.character+' '+c.card_name+' '+c.house+' '+
        (c.active_skills||[]).map(s=>s.name+' '+s.description).join(' ')+' '+
        (c.unique_skill?c.unique_skill.name+' '+c.unique_skill.description:'')).toLowerCase();
      if(!blob.includes(state.q)) return false;
    }
    return true;
  });
  list.forEach(c=>{ c._score=scoreOf(c,weights); });
  const s=state.sort;
  list.sort((a,b)=>{
    if(s==='rank') return b._score-a._score;
    if(s==='speed') return (a._raw.entry-b._raw.entry) || (b._score-a._score);
    if(s==='name') return a.card_name.localeCompare(b.card_name);
    if(s==='char') return a.character.localeCompare(b.character) || b._score-a._score;
  });
  return list;
}

function cardHTML(c, idx){
  const tier=tierOf(c._score);
  const rankNo = state.sort==='rank' ? `<span class="rnum">#${idx+1}</span>` : '';
  return `<div class="card" tabindex="0" data-id="${c.card_name}">
    <div class="imgwrap">
      <img loading="lazy" src="${c.image}" alt="${c.full_name}">
      <div class="rankbadge"><span class="tier ${tier}">${tier}</span>${rankNo}</div>
      <div class="chips"><span class="dot ${c.card_type}"></span><span class="stype-pill">${c.skill_type.replace(' Attacker','').replace('.','')}</span></div>
      <div class="cinfo">
        <div class="cchar">${c.character}</div>
        <div class="cname">${c.card_name}</div>
        <div class="cscore"><div class="bar"><i style="width:${c._score.toFixed(0)}%"></i></div><span class="sval">${c._score.toFixed(1)}</span></div>
      </div>
    </div>
  </div>`;
}

function render(){
  const list=filtered();
  const grid=document.getElementById('grid');
  document.getElementById('showN').textContent=list.length;
  document.getElementById('totN').textContent=CARDS.length;
  const sortName=(SORTS.find(s=>s[0]===state.sort)||[])[1]||'';
  document.getElementById('sortLbl').innerHTML = state.sort==='rank'
    ? `가중치 순위 · <span style="color:var(--gold)">O ${weights.offense} · B ${weights.burst} · S ${weights.speed} · M ${weights.mp} · U ${weights.util}</span>`
    : `정렬: ${sortName}`;
  if(!list.length){
    grid.innerHTML=`<div class="empty"><b>일치하는 카드가 없습니다</b>필터나 검색어를 조정해 보세요.</div>`;
    return;
  }
  grid.innerHTML=list.map((c,i)=>cardHTML(c,i)).join('');
  grid.querySelectorAll('.card').forEach(el=>{
    el.onclick=()=>openCard(el.dataset.id);
    el.onkeydown=e=>{ if(e.key==='Enter'||e.key===' '){e.preventDefault();openCard(el.dataset.id);} };
  });
}

/* ---------- detail modal ---------- */
function skillStat(cls,label,val){ return `<span class="st ${cls}">${label} <b>${val}</b></span>`; }

function activeSkillHTML(s){
  const dmg = isDamaging(s);
  const delay = s.tu!=null ? Math.max(ceilStep(s.tu),0) : null;
  const stats=[];
  if(s.tu!=null) stats.push(skillStat('tu','TU',s.tu));
  if(delay!=null) stats.push(skillStat('delay','행동지연',`+${delay}`));
  if(s.mp!=null){
    if(s.mp<0) stats.push(skillStat('mp-cost','MP',s.mp));
    else if(s.mp>0) stats.push(skillStat('mp-gain','MP',`+${s.mp}`));
    else stats.push(skillStat('mp','MP','0'));
  }
  if(s.damage) stats.push(skillStat('dmg','속성',s.damage));
  if(s.target) stats.push(skillStat('tgt','대상',s.target));
  if(s.multiplier!=null) stats.push(skillStat('dmg','배율',s.multiplier+'x'));
  return `<div class="skill">
    <div class="sk-top"><div><div class="sk-name">${s.name||'—'}</div></div></div>
    ${s.description?`<div class="sk-desc">${s.description}</div>`:''}
    <div class="sk-stats">${stats.join('')}</div>
  </div>`;
}

