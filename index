/* ---------- ranking engine ---------- */
const AOE_ENEMIES = 3;              // "All" 대상 수 가정
const MP_START = 5, MP_MIN = 0, MP_MAX = 10;

function ceilStep(v){ return Math.ceil((v - 100) / 10); }     // TU / speed → step 지연
function targetCount(t){
  if(t == null) return 0;
  const s = String(t).toLowerCase();
  if(s === 'all') return AOE_ENEMIES;
  const n = parseInt(s,10);
  return Number.isNaN(n) ? 0 : n;
}
function isDamaging(sk){ return sk.multiplier != null && targetCount(sk.target) > 0; }

// 유틸리티 키워드 스코어링
const UTIL_KW = [
  [/survives? with 1 ?hp|lethal damage/i, 3],
  [/revive|resurrect/i, 3],
  [/heal|restore .*hp|recover .*hp/i, 2],
  [/barrier|shield|damage reduction|reduces? .*damage|nullif/i, 2],
  [/ignore.*def|guaranteed|cannot be|unaffected/i, 2],
  [/increases? (own|ally|this).*(atk|attack)|p ?atk|s ?atk|up\b/i, 2],
  [/crit/i, 1],
  [/gains? .*mp|restore .*mp|\bmp\b/i, 1],
  [/reduces? .*enemy|debuff|lower|weaken/i, 1],
  [/cleanse|remove.*debuff|dispel/i, 1],
  [/fury|charge|stack|buff/i, 1],
];
function utilRaw(card){
  let s = 0;
  const texts = [];
  (card.passive_skills||[]).forEach(p=>{ if(p.description) texts.push(p.description); });
  if(card.unique_skill && card.unique_skill.description) texts.push(card.unique_skill.description);
  (card.active_skills||[]).forEach(a=>{ if(!isDamaging(a) && a.description) texts.push(a.description); });
  const blob = texts.join(' \n ');
  UTIL_KW.forEach(([re,w])=>{ if(re.test(blob)) s += w; });
  return s;
}

function medianSpeed(cards){
  const v = cards.map(c=>c.speed).filter(x=>x!=null).sort((a,b)=>a-b);
  return v.length ? v[Math.floor(v.length/2)] : 130;
}

let MED_SPEED = 130;

// 카드별 원시(raw) 서브스코어 계산
function computeRaw(card){
  const dmg = (card.active_skills||[]).filter(isDamaging);
  let offense = 0, burst = 0;
  dmg.forEach(s=>{
    const tc = targetCount(s.target);
    const eff = s.multiplier * tc;
    const delay = Math.max(ceilStep(s.tu||100), 1);
    offense = Math.max(offense, eff / delay);
    burst = Math.max(burst, eff);
  });
  const spd = card.speed != null ? card.speed : MED_SPEED;
  const entry = ceilStep(spd);
  const speedRaw = -entry;                     // 지연 낮을수록 좋음
  // MP 경제
  const gens = (card.active_skills||[]).map(s=>s.mp).filter(m=>m!=null && m>0);
  const bestGen = gens.length ? Math.max(...gens) : 0;
  let cheapCost = Infinity;
  dmg.forEach(s=>{ const c = s.mp!=null ? Math.max(-s.mp,0) : 2; cheapCost = Math.min(cheapCost, c); });
  if(!isFinite(cheapCost)) cheapCost = 0;
  const mpRaw = bestGen * 1.5 + (cheapCost===0?3:0) - cheapCost;
  return {
    offense, burst, speed: speedRaw, mp: mpRaw, util: utilRaw(card),
    entry, spdUsed: spd, spdEst: card.speed==null,
    hasData: dmg.length>0 || (card.passive_skills||[]).length>0 || !!card.unique_skill
  };
}

function normalizeAll(cards){
  MED_SPEED = medianSpeed(cards);
  const raws = cards.map(computeRaw);
  const keys = ['offense','burst','speed','mp','util'];
  const ranges = {};
  keys.forEach(k=>{
    let mn=Infinity, mx=-Infinity;
    raws.forEach(r=>{ mn=Math.min(mn,r[k]); mx=Math.max(mx,r[k]); });
    ranges[k]=[mn,mx];
  });
  cards.forEach((c,i)=>{
    const r = raws[i];
    const norm = {};
    keys.forEach(k=>{
      const [mn,mx]=ranges[k];
      norm[k] = mx>mn ? ((r[k]-mn)/(mx-mn))*100 : 50;
    });
    c._raw = r; c._sub = norm;
  });
}

function scoreOf(card, w){
  const s = card._sub;
  const sum = w.offense+w.burst+w.speed+w.mp+w.util || 1;
  return (s.offense*w.offense + s.burst*w.burst + s.speed*w.speed + s.mp*w.mp + s.util*w.util)/sum;
}

function tierOf(score){
  if(score>=80) return 'S';
  if(score>=65) return 'A';
  if(score>=50) return 'B';
  if(score>=32) return 'C';
  return 'D';
}

